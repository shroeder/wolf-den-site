{
    "buildCommand": "bash scripts/build.sh",
    "trailingSlash": false,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/sitemap"
        },
        {
            "source": "/robots.txt",
            "destination": "/robots"
        }
    ],
    "crons": [
        {
            "path": "/api/jobs/consignment-nightly-reports",
            "schedule": "30 7 * * *"
        },
        {
            "path": "/api/jobs/tcg-catalog-sync",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/jobs/marketplace-reprice",
            "schedule": "45 6 * * *"
        },
        {
            "path": "/api/jobs/looking-for-alerts",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/jobs/inventory-feed",
            "schedule": "*/15 * * * *"
        }
    ]
}